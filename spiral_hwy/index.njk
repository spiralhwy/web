<!DOCTYPE html>
<html lang="en">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <meta name="description" content="Spiral HWY - San Francisco Cinema">
        <meta name="keywords" content="Spiral HWY, San Francisco cinema, San Francisco theaters, indie films, independent theater, movie showings, San Francisco events">
        <title>Spiral HWY</title>
        <link rel="stylesheet" href="styles.css">
    </head>
    <body>
        <header id="top">
            <h1 class="site-title">Spiral HWY</h1>
            <h2 class="site-subtitle">San Francisco Cinema</h2>
        </header>

        <div id="calendar">
            <div class="cal-header">
                <button id="cal-prev" class="cal-nav">&lt;</button>
                <span id="cal-month-label" class="cal-month-label"></span>
                <button id="cal-next" class="cal-nav">&gt;</button>
            </div>
            <div class="cal-grid">
                <span class="cal-dow">Su</span>
                <span class="cal-dow">Mo</span>
                <span class="cal-dow">Tu</span>
                <span class="cal-dow">We</span>
                <span class="cal-dow">Th</span>
                <span class="cal-dow">Fr</span>
                <span class="cal-dow">Sa</span>
            </div>
            <div id="cal-days" class="cal-grid"></div>
        </div>

        </br>
        {% if movies %}
            {% for m in movies %}
                <div class="sticky-wrapper" id="date-{{ m.date }}">
                    <div class="date">{{ m.date | formatDate }}</div>
                    <a href="#" class="top-btn" aria-label="Back to top">↑</a>
                </div>
                {% for movie_data in m.movies %}
                    <div class="movie-block">
                        <h2 class="movie-title">{{ movie_data.title }}</h2>
                        <div class="poster-container">
                            <img 
                                src="posters/{{ movie_data.poster }}.png" 
                                alt="Poster for {{ movie_data.title }}"
                                width="120"
                                height="180"
                            >
                        </div>
                        <div class="movie-info">
                            {% for listing in movie_data.listings %}
                                <div class="theater-info">
                                    <a href="{{ listing.theater_link }}" target="_blank" class="theater-name">
                                        {{ listing.theater | replace("_", " ") | title }}
                                    </a> 
                                    <a href="{{ listing.map }}" target="_blank" class="area-link" >
                                        {{ listing.area | replace("_", " ") | title }}
                                    </a>
                                    <span class="showtimes">
                                        {% for showing in listing.showings %}
                                            <a href="{{ showing.link }}" 
                                            target="_blank" 
                                            class="time {% if showing.available == 'SOLD OUT' %}sold-out{% endif %}">
                                                {{ showing.time | formatTime }}
                                            </a>
                                            {% if not loop.last %} | {% endif %}
                                        {% endfor %}  {# showing #}
                                    </span>
                                </div>
                            {% endfor %}  {# theater #}
                        </div>
                    </div>
                    {% if not loop.last %}
                        <div class="divider"></div>
                    {% else %}
                    {% for _ in range(4) %}</br>{% endfor %}  {# spacing #}
                    {% endif %}
                {% endfor %}  {# movie #}
            {% endfor %}  {# date #}
        {% else %}
            <p>No movie data available</p>
        {% endif %}
        <script>
            const header = document.getElementById('top');
            const wrappers = document.querySelectorAll('.sticky-wrapper');
            const headerObserver = new IntersectionObserver(([entry]) => {
                const pastHeader = !entry.isIntersecting;
                wrappers.forEach(w => w.classList.toggle('past-header', pastHeader));
            });
            headerObserver.observe(header);

            const stickyObserver = new IntersectionObserver((entries) => {
                entries.forEach(entry => {
                    entry.target.classList.toggle('stuck', entry.intersectionRatio < 1);
                });
            }, { threshold: 1, rootMargin: '-1px 0px 0px 0px' });
            wrappers.forEach(w => stickyObserver.observe(w));

            document.querySelectorAll('.top-btn').forEach(btn => {
                btn.addEventListener('click', (e) => {
                    e.preventDefault();
                    window.scrollTo({ top: 0, behavior: 'smooth' });
                });
            });
        (function() {
            const dates = [{% for m in movies %}"{{ m.date }}"{% if not loop.last %},{% endif %}{% endfor %}];
            const dateSet = new Set(dates);

            const firstDate = dates[0];
            const lastDate = dates[dates.length - 1];
            const firstMonth = new Date(firstDate.replace(/-/g, '/'));
            firstMonth.setDate(1);
            const lastMonth = new Date(lastDate.replace(/-/g, '/'));
            lastMonth.setDate(1);

            // build list of months to render (first to last, inclusive)
            const months = [];
            const cursor = new Date(firstMonth);
            while (cursor <= lastMonth) {
                months.push(new Date(cursor));
                cursor.setMonth(cursor.getMonth() + 1);
            }

            let currentIdx = 0;
            // start on the month containing today if possible
            const today = new Date();
            const todayStr = today.getFullYear() + '-' +
                String(today.getMonth() + 1).padStart(2, '0') + '-' +
                String(today.getDate()).padStart(2, '0');
            for (let i = 0; i < months.length; i++) {
                if (today.getFullYear() === months[i].getFullYear() &&
                    today.getMonth() === months[i].getMonth()) {
                    currentIdx = i;
                    break;
                }
            }

            const monthNames = ['January','February','March','April','May','June',
                                'July','August','September','October','November','December'];
            const label = document.getElementById('cal-month-label');
            const daysEl = document.getElementById('cal-days');
            const prevBtn = document.getElementById('cal-prev');
            const nextBtn = document.getElementById('cal-next');

            function pad(n) { return String(n).padStart(2, '0'); }

            function render() {
                const m = months[currentIdx];
                const year = m.getFullYear();
                const month = m.getMonth();
                label.textContent = monthNames[month] + ' ' + year;

                // prev/next visibility
                prevBtn.style.visibility = currentIdx === 0 ? 'hidden' : 'visible';
                nextBtn.style.visibility = currentIdx === months.length - 1 ? 'hidden' : 'visible';

                // build days
                const firstDow = new Date(year, month, 1).getDay();
                const daysInMonth = new Date(year, month + 1, 0).getDate();

                let html = '';
                // blank cells for offset
                for (let i = 0; i < firstDow; i++) {
                    html += '<span class="cal-day"></span>';
                }
                for (let d = 1; d <= daysInMonth; d++) {
                    const ds = year + '-' + pad(month + 1) + '-' + pad(d);
                    const hasListings = dateSet.has(ds);
                    const isToday = ds === todayStr;
                    let cls = 'cal-day';
                    if (hasListings) cls += ' cal-day-active';
                    else cls += ' cal-day-inactive';
                    if (isToday) cls += ' cal-day-today';
                    if (hasListings) {
                        html += '<a href="#date-' + ds + '" class="' + cls + '">' + d + '</a>';
                    } else {
                        html += '<span class="' + cls + '">' + d + '</span>';
                    }
                }
                daysEl.innerHTML = html;

                // smooth scroll on click
                daysEl.querySelectorAll('a.cal-day-active').forEach(function(el) {
                    el.addEventListener('click', function(e) {
                        e.preventDefault();
                        var target = document.querySelector(el.getAttribute('href'));
                        if (target) {
                            target.scrollIntoView({ behavior: 'smooth' });
                        }
                    });
                });
            }

            prevBtn.addEventListener('click', function() {
                if (currentIdx > 0) { currentIdx--; render(); }
            });
            nextBtn.addEventListener('click', function() {
                if (currentIdx < months.length - 1) { currentIdx++; render(); }
            });

            render();
        })();
        </script>
    </body>
</html>
